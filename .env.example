cd # Environment Variables — WTF LivePulse
# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by the backend at runtime
DATABASE_URL=postgres://wtf:wtf_secret@localhost:5432/wtf_livepulse

# Separate database used by Jest integration tests (pg-mem handles this in-memory,
# but a real URL is needed if you want to run against an actual Postgres instance)
TEST_DATABASE_URL=postgres://wtf:wtf_secret@localhost:5432/wtf_livepulse_test

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend (Vite build-time) ───────────────────────────────────────────────
# Base URL of the backend REST API (consumed by Vite during build)
VITE_API_URL=http://localhost:3001

# WebSocket URL for Socket.io client
VITE_WS_URL=http://localhost:3001

# ─── pnpm ────────────────────────────────────────────────────────────────────
# Pin pnpm version for reproducible CI installs
PNPM_VERSION=10.0.0

